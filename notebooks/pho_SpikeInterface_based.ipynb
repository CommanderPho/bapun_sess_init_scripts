            ]
          },
          "metadata": {},
          "output_type": "display_data"
        },
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "create_sorting_analyzer: recording does not have scaling to uV, forcing return_in_uV=False\n"
          ]
        },
        {
          "data": {
            "application/vnd.jupyter.widget-view+json": {
              "model_id": "68ee08a5d8504cb5b786bc14752acb5e",
              "version_major": 2,
              "version_minor": 0
            },
            "text/plain": [
              "noise_level (no parallelization):   0%|          | 0/20 [00:00<?, ?it/s]"
            ]
