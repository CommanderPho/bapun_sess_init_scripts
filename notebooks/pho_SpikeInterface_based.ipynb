      "source": [
        "import spikeinterface.core as si\n",
        "from spikeinterface.metrics import (\n",
        "    compute_snrs,\n",
        "    compute_presence_ratios,\n",
        "    compute_isi_violations,\n",
        ")"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "7460df15",
      "metadata": {},
      "source": [
        "First, let's generate a simulated recording and sorting\n",
        "\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "de20f5fa",
      "metadata": {},
      "outputs": [
        {
          "data": {
            "application/vnd.jupyter.widget-view+json": {
              "model_id": "cc6f24ea8cca4abcaf4b9591ae107bef",
              "version_major": 2,
