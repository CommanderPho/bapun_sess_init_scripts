        },
        {
          "data": {
            "application/vnd.jupyter.widget-view+json": {
              "model_id": "88c728d09afa424d929baeb0d906d730",
              "version_major": 2,
              "version_minor": 0
            },
            "text/plain": [
              "compute_waveforms (no parallelization):   0%|          | 0/4371 [00:00<?, ?it/s]"
            ]
          },
          "metadata": {},
          "output_type": "display_data"
        }
      ],
      "source": [
        "# sorting = sorting_TDC\n",
        "# sorting_analyzer = sorting_TDC.to_shared_memory_sorting()\n",
        "\n",
        "sorting_analyzer = si.create_sorting_analyzer(sorting=sorting, recording=recording_filtered)\n",
        "sorting_analyzer.compute(['noise_levels','random_spikes','waveforms','templates','spike_locations','spike_amplitudes','correlograms','principal_components','quality_metrics','template_metrics'])\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "c1be7470",
      "metadata": {},
      "outputs": [],
      "source": [
        "sorting_analyzer.compute('template_metrics', include_multi_channel_metrics=True) \n",
        "\n",
        "# sorting = sorting_TDC\n",
        "# sorting_analyzer = sorting_TDC.to_shared_memory_sorting()\n",
        "\n",
        "sorting_analyzer = si.create_sorting_analyzer(sorting=sorting, recording=recording_filtered)\n",
        "sorting_analyzer.compute(['noise_levels','random_spikes','waveforms','templates','spike_locations','spike_amplitudes','correlograms','principal_components','quality_metrics','template_metrics'])\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "c1be7470",
      "metadata": {},
      "outputs": [],
      "source": [
        "sorting_analyzer.compute('template_metrics', include_multi_channel_metrics=True) \n",
        "\n",
        "# recording, sorting = si.generate_ground_truth_recording()\n",
        "# print(recording)\n",
        "# print(sorting)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "305a1b80",
      "metadata": {},
      "outputs": [],
      "source": [
        "all_metric_names = list(sorting_analyzer.get_extension('quality_metrics').get_data().keys()) + list(sorting_analyzer.get_extension('template_metrics').get_data().keys())\n",
        "print(set(model.feature_names_in_).issubset(set(all_metric_names)))"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "305a1b80",
      "metadata": {},
      "outputs": [],
      "source": [
        "all_metric_names = list(sorting_analyzer.get_extension('quality_metrics').get_data().keys()) + list(sorting_analyzer.get_extension('template_metrics').get_data().keys())\n",
        "print(set(model.feature_names_in_).issubset(set(all_metric_names)))"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "a997692f",
      "metadata": {},
      "source": [
        "## Create SortingAnalyzer\n",
        "\n",
        "For quality metrics we need first to create a :code:`SortingAnalyzer`.\n",
        "\n"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "e642b48a",
      "metadata": {},
      "source": [
        "The :code:`spikeinterface.qualitymetrics` submodule has a set of functions that allow users to compute\n",
        "metrics in a compact and easy way. To compute a single metric, one can simply run one of the\n",
        "quality metric functions as shown below. Each function has a variety of adjustable parameters that can be tuned.\n",
        "\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "88082ef6",
      "metadata": {},
      "outputs": [],
      "source": [
        "## INPUTS: sorting_analyzer\n",
        "presence_ratios = compute_presence_ratios(sorting_analyzer)\n",
        "print(presence_ratios)\n",
        "isi_violation_ratio, isi_violations_count = compute_isi_violations(sorting_analyzer)\n",
        "print(isi_violation_ratio)\n",
        "snrs = compute_snrs(sorting_analyzer)\n",
        "print(snrs)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "905e1707",
      "metadata": {},
      "outputs": [],
      "source": [
        "labels = sc.model_based_label_units(\n",
        "    sorting_analyzer = sorting_analyzer,\n",
        "    repo_id = \"SpikeInterface/toy_tetrode_model\",\n",
        "    trusted = ['numpy.dtype']\n",
        ")\n",
        "\n",
        "print(labels)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "905e1707",
      "metadata": {},
      "outputs": [],
      "source": [
        "labels = sc.model_based_label_units(\n",
        "    sorting_analyzer = sorting_analyzer,\n",
        "    repo_id = \"SpikeInterface/toy_tetrode_model\",\n",
        "    trusted = ['numpy.dtype']\n",
        ")\n",
        "\n",
        "print(labels)"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "dc169eff",
      "metadata": {},
      "source": [
        "To compute more than one metric at once, we can use the :code:`SortingAnalyzer.compute(\"quality_metrics\")`\n",
        "function and indicate which metrics we want to compute. Then we can retrieve the results using the :code:`get_data()`\n",
        "method as a ``pandas.DataFrame``.\n",
        "\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "9d89a229",
      "metadata": {},
      "outputs": [],
      "source": [
        "metrics_ext = sorting_analyzer.compute(\n",
        "    \"quality_metrics\",\n",
        "    metric_names=[\"presence_ratio\", \"snr\", \"amplitude_cutoff\"],\n",
        "    metric_params={\n",
        "        \"presence_ratio\": {\"bin_duration_s\": 2.0},\n",
        "    }\n",
        ")\n",
        "metrics = metrics_ext.get_data()\n",
        "print(metrics)"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "97127186",
      "metadata": {},
      "source": [
        "Some metrics are based on the principal component scores, so the extension\n",
        "must be computed before. For instance:\n",
        "\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "df9a1dac",
      "metadata": {},
      "outputs": [],
      "source": [
        "sorting_analyzer.compute(\"principal_components\", n_components=5, mode=\"by_channel_global\", whiten=True)\n",
        "\n",
        "metrics_ext = sorting_analyzer.compute(\n",
        "    \"quality_metrics\",\n",
        "    metric_names=[\n",
        "        \"mahalanobis\",\n",
        "        \"d_prime\",\n",
        "    ],\n",
        ")\n",
        "metrics = metrics_ext.get_data()\n",
        "print(metrics)"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "e5970135",
      "metadata": {},
      "source": [
        "# Trained Models"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "598f0a88",
      "metadata": {},
      "outputs": [],
      "source": [
        "from spikeinterface.curation import model_based_label_units\n",
        "\n",
        "labels_and_probabilities = model_based_label_units(\n",
        "    sorting_analyzer = sorting_analyzer,\n",
        "    repo_id = \"SpikeInterface/toy_tetrode_model\",\n",
        "    trust_model = True\n",
        ")"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "7a556b62",
      "metadata": {},
      "source": [
        "# Apply to Phy Data"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "3da3f711",
      "metadata": {
        "tags": [
          "run-phy-model"
        ]
      },
      "outputs": [
        {
          "data": {
            "application/vnd.jupyter.widget-view+json": {
              "model_id": "9280d4e5d9c7483db5efa1433afea2b7",
              "version_major": 2,
              "version_minor": 0
            },
            "text/plain": [
              "estimate_sparsity (no parallelization):   0%|          | 0/4371 [00:00<?, ?it/s]"
            ]
          },
          "metadata": {},
          "output_type": "display_data"
        }
      ],
      "source": [
        "import spikeinterface.curation as sc\n",
        "\n",
        "## INPUTS: sorting = se.read_phy(phy_gui_dir)\n",
        "\n",
        "job_kwargs = dict(n_jobs=8, progress_bar=True, chunk_duration=\"4s\")\n",
        "\n",
        "sorting_analyzer_folder = windows_to_wsl_path_if_needed(basedir.joinpath(\"spyk-circ\", f\"{basename}-phy-sorting_analyzer\").resolve())\n",
        "\n",
        "sorting_analyzer = si.create_sorting_analyzer(\n",
        "    sorting=sorting,\n",
        "    recording=recording_filtered,\n",
        "    format=\"binary_folder\",\n",
        "    folder=sorting_analyzer_folder.as_posix(),\n",
        "    overwrite=True,\n",
        ")\n",
        "\n",
        "sorting_analyzer.compute([\n",
        "    \"noise_levels\", \"random_spikes\", \"waveforms\", \"templates\",\n",
        "    \"spike_locations\", \"spike_amplitudes\", \"correlograms\",\n",
        "    \"principal_components\", \"quality_metrics\", \"template_metrics\",\n",
        "], **job_kwargs)\n",
        "\n",
        "sorting_analyzer.compute(\"template_metrics\", include_multi_channel_metrics=True)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "483f667a",
      "metadata": {
        "tags": [
          "run-phy-model"
        ]
      },
      "outputs": [],
      "source": [
        "model, model_info = sc.load_model(\n",
        "    repo_id=\"SpikeInterface/UnitRefine_noise_neural_classifier\",\n",
        "    trust_model=True,\n",
        ")\n",
        "\n",
        "all_metric_names = (\n",
        "    list(sorting_analyzer.get_extension(\"quality_metrics\").get_data().keys())\n",
        "    + list(sorting_analyzer.get_extension(\"template_metrics\").get_data().keys())\n",
        ")\n",
        "print(\"model features:\", model.feature_names_in_)\n",
        "print(\"all present?:\", set(model.feature_names_in_).issubset(set(all_metric_names)))\n",
        "print(\"missing:\", set(model.feature_names_in_) - set(all_metric_names))"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "e553a629",
      "metadata": {
        "tags": [
          "run-phy-model"
        ]
      },
      "outputs": [],
      "source": [
        "# Step A: noise vs neural\n",
        "noise_neural_labels = sc.model_based_label_units(\n",
        "    sorting_analyzer=sorting_analyzer,\n",
        "    repo_id=\"SpikeInterface/UnitRefine_noise_neural_classifier\",\n",
        "    trust_model=True,\n",
        ")\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "44cb6809",
      "metadata": {
        "tags": [
          "run-phy-model"
        ]
      },
      "outputs": [],
      "source": [
        "noise_units = noise_neural_labels[noise_neural_labels[\"prediction\"] == \"noise\"]\n",
        "analyzer_neural = sorting_analyzer.remove_units(noise_units.index)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "2377bcee",
      "metadata": {
        "tags": [
          "run-phy-model"
        ]
      },
      "outputs": [],
      "source": [
        "# Step B: SUA vs MUA on remaining units\n",
        "sua_mua_labels = sc.model_based_label_units(\n",
        "    sorting_analyzer=analyzer_neural,\n",
        "    repo_id=\"SpikeInterface/UnitRefine_sua_mua_classifier\",\n",
        "    trust_model=True,\n",
        ")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "32333b87",
      "metadata": {
        "tags": [
          "run-phy-model"
        ]
      },
      "outputs": [],
      "source": [
        "import pandas as pd\n",
        "all_labels = pd.concat([sua_mua_labels, noise_units]).sort_index()\n",
        "print(all_labels[\"prediction\"].value_counts())\n",
        "print(all_labels.head())"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "dc70d938",
      "metadata": {
        "tags": [
          "run-phy-model"
        ]
      },
      "outputs": [],
      "source": [
        "phy_labels = sorting.get_property(\"quality\")\n",
        "comparison = all_labels.copy()\n",
        "comparison[\"phy_label\"] = phy_labels\n",
        "comparison[\"agreement\"] = comparison[\"prediction\"] == comparison[\"phy_label\"]\n",
        "print(comparison.groupby([\"phy_label\", \"prediction\"]).size())"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "e3f1983b",
      "metadata": {
        "tags": [
          "run-phy-model"
        ]
      },
      "outputs": [],
      "source": [
        "good_units = all_labels[\n",
        "    (all_labels[\"prediction\"] == \"sua\")  # or map sua -> good for your pipeline\n",
        "    & (all_labels[\"probability\"] > 0.8)  # tune threshold\n",
        "].index\n",
        "\n",
        "sorting_curated = sorting.remove_units(\n",
        "    remove_unit_ids=[u for u in sorting.get_unit_ids() if u not in good_units]\n",
        ")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "0d7f8e38",
      "metadata": {
        "tags": [
          "run-phy-model"
        ]
      },
      "outputs": [],
      "source": [
        "# sua -> good, mua -> mua, noise -> noise\n",
        "label_map = {\"sua\": \"good\", \"mua\": \"mua\", \"neural\": \"unclassified\", \"noise\": \"noise\"}\n",
        "sorting.set_property(\"auto_quality\", [label_map.get(p, \"unclassified\") for p in all_labels.loc[sorting.get_unit_ids(), \"prediction\"]])"
      ]
    }
  ],
